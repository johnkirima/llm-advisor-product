# LLM Advisor — Environment Variables
# Copy to .env.local for local development, or set these in Azure App Service
# Configuration → Application settings when deploying.
#
# Never commit this file with real values — .env* is gitignored.

# Supabase (get from https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_KEY=eyJhbGciOi...
